---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="IoTera"
  description="IoTera is under construction."
>
  <section class="flex min-h-screen items-center justify-center px-6">
    <div class="flex flex-col items-center gap-4 text-center">
      <img
        src="/iotera-logo.png"
        alt="IoTera"
        class="h-auto w-full max-w-[220px] sm:max-w-[280px]"
      />
      <p class="text-base font-medium tracking-[0.18em] text-slate-500 uppercase sm:text-lg">
        Under construction
      </p>
    </div>
  </section>
</BaseLayout>
